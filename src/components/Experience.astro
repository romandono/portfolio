---
import { getCollection } from 'astro:content';

export interface Props {
  dict: {
    title: string;
    present: string;
    entries: Record<string, { role: string; description: string }>;
  };
}

const { dict } = Astro.props;
const entries = await getCollection('experience');
entries.sort((a, b) => a.data.order - b.data.order);
---

<section class="section" id="experience">
  <div class="container">
    <h2 class="section-title">{dict.title}</h2>
    <div class="experience-list">
      {entries.map((e) => {
        const t = dict.entries[e.id] || { role: e.data.role, description: e.data.description };
        return (
          <article class="experience-card">
            <div class="experience-card__period">
              <span>{e.data.startDate}</span>
              <span>—</span>
              <span>{e.data.endDate ?? dict.present}</span>
            </div>
            <div class="experience-card__content">
              <h3>
                {e.data.url ? (
                  <a href={e.data.url} target="_blank" rel="noopener noreferrer">{t.role}</a>
                ) : (
                  t.role
                )}
              </h3>
              <p class="experience-card__company">{e.data.company}</p>
              <p class="experience-card__description">{t.description}</p>
              <div class="experience-card__tags">
                {e.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .experience-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: var(--radius-md);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    transition: all var(--transition);
  }

  .experience-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .experience-card__period {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    display: flex;
    gap: 0.5rem;
  }

  .experience-card__content h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .experience-card__company {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .experience-card__description {
    font-size: 0.925rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .experience-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .experience-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
